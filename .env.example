# =========================================================================
# IOMAD / eLEARNING_deploy — variables d'environnement
# Copier en .env :  cp .env.example .env   (le .env n'est PAS versionné)
# =========================================================================

# === Base de données (PostgreSQL externe, ex: Dokploy) ===
MOODLE_DB_TYPE=pgsql
MOODLE_DB_HOST=
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=iomad
MOODLE_DB_USER=iomad
MOODLE_DB_PASSWORD=
MOODLE_DB_PREFIX=mdl_

# === Accès VPN ZeroTier (la plateforme n'est joignable que par le VPN) ===
# IP du serveur sur le VPN ZeroTier : le port n'est publié que sur cette IP.
ZEROTIER_IP=10.95.135.150
APP_PORT=4000

# === Site ===
# DOIT correspondre exactement à l'URL tapée dans le navigateur.
# Accès VPN direct (HTTP) -> http://10.95.135.150:4000
MOODLE_WWW_ROOT=http://10.95.135.150:4000
# true SEULEMENT derrière un reverse proxy qui termine le SSL (Traefik/Dokploy).
# Accès VPN direct en HTTP -> false
MOODLE_SSLPROXY=false
# false = interdit l'upload de plugins via l'UI (recommandé en prod).
# Mets true en dev si tu veux installer des plugins depuis le navigateur.
MOODLE_DISABLE_AUTODEPLOY=false

# === Installation automatique au 1er boot (base vide) ===
# Si MOODLE_ADMIN_PASSWORD est vide -> l'install se fera via le navigateur.
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_SITE_FULLNAME=IOMAD eLearning
MOODLE_SITE_SHORTNAME=iomad
MOODLE_LANG=fr

# === PHP Tuning ===
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_VARS=5000

# === OPcache ===
OPCACHE_ENABLE=1
OPCACHE_MEMORY=256

# === Migration (utilisé par scripts/backup.sh & restore.sh) ===
# Préfixe des volumes Docker (= nom du dossier projet en minuscules par défaut)
VOLUME_PREFIX=elearning_deploy
# Réseau pour joindre la DB lors d'un pg_dump/pg_restore
DOKPLOY_NETWORK=dokploy-network
